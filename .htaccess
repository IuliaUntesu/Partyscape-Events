# Define the default file for a directory
DirectoryIndex index.html

# Rule for 404 errors (Points to your /404/ folder's index.html)
ErrorDocument 404 /404/

# Enable the URL rewriting engine
RewriteEngine On
RewriteBase /

# 1. External Redirect: Force /page.html to clean URL /page/
# (This updates old links for SEO)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^.]+)\.html\ HTTP/
RewriteRule ^([^.]+)\.html$ /$1/ [R=301,L]

# 2. Internal Rewrite: SECRETLY load the .html file when a user visits /page/
# (Without this, your clean URLs will all return a 404 error!)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^([^/]+)/?$ $1.html [L]

# 3. Trailing Slash: Ensure that folder requests get a trailing slash
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.+[^/])$ %{REQUEST_URI}/ [R=301,L]
